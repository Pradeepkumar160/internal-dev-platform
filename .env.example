# ============================================================
# Internal Developer Platform - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values

# ------ REQUIRED ------

# JWT Secret - CHANGE THIS! Use: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# ------ APP SETTINGS ------

# Server port (default: 5174)
PORT=5174

# ------ OAUTH (for production login) ------
# If you don't have OAuth, the app uses the dev-login endpoint.
# To connect a real OAuth provider, fill these in.
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ------ OPTIONAL ------

# Set to "true" to allow the dev-login in production (NOT recommended for real production)
ALLOW_DEV_LOGIN=false

# Analytics (leave blank to disable)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
